<?xml version="1.0"?>
<robot name="sim_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 ${h/2}" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0.0" ixz="0.0"
               iyy="${(m/12) * (3*r*r + h*h)}" iyz="0.0"
               izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <origin xyz="0 0 ${z/2}" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (y*y + z*z)}" ixy="0.0" ixz="0.0"
               iyy="${(m/12) * (x*x + z*z)}" iyz="0.0"
               izz="${(m/12) * (x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <link name="base_link"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_plate"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_plate">
    <visual>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.5" r="0.1" h="0.05"/>
  </link>

  <joint name="base_yaw_joint" type="revolute">
    <parent link="base_plate"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.025" rpy="0 0 0"/>
    <axis xyz="0 0 1"/> 
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <link name="shoulder_link">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.08"/> 
      </geometry>
      <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.04" length="0.08"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.2" r="0.04" h="0.08"/>
  </link>

  <joint name="shoulder_pitch_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="bicep_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/> 
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <link name="bicep_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.03" length="0.2"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/> 
      <geometry>
        <cylinder radius="0.03" length="0.2"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.4" r="0.03" h="0.2"/>
  </link>

  <joint name="elbow_pitch_joint" type="revolute">
    <parent link="bicep_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
      <material name="yellow">
        <color rgba="0.8 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/> 
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.3" r="0.025" h="0.15"/>
  </link>

  <joint name="wrist_pitch_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <link name="wrist_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/> 
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.1" x="0.05" y="0.05" z="0.05"/>
  </link>

  <joint name="wrist_roll_joint" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/> 
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="1"/>
  </joint>

  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0.01" rpy="0 0 0"/> 
      <geometry>
        <cylinder radius="0.02" length="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.01" rpy="0 0 0"/> 
      <geometry>
        <cylinder radius="0.02" length="0.02"/> 
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="0.1" r="0.02" h="0.02"/>
  </link>

<!-- COMENTADO PARA EL DEMO DE MOVEIT
